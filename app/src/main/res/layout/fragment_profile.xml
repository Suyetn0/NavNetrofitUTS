<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F5F5F5"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="@android:color/white">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfile"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/suyetno"
                android:scaleType="centerCrop"
                android:padding="4dp"
                app:strokeWidth="3dp"
                app:strokeColor="#6200EE"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
                app:shapeAppearance="@style/ShapeAppearance.MaterialComponents.SmallComponent"/>

            <TextView
                android:id="@+id/tvNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUYETNO"
                android:textColor="#212121"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>

            <View
                android:layout_width="100dp"
                android:layout_height="2dp"
                android:background="#6200EE"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvNim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM : 6304250090"
                android:textColor="#757575"
                android:textSize="18sp"
                android:textStyle="italic"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas : RPL 2D"
                    android:textColor="#424242"
                    android:textSize="16sp"
                    android:paddingEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="|"
                    android:textColor="#DDDDDD"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvProdi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teknik Informatika"
                    android:textColor="#424242"
                    android:textSize="16sp"
                    android:paddingStart="12dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>